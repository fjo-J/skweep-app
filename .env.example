# =====================================================================
# Skweep — 環境変数サンプル
# このファイルをコピーして .env.local を作成し、値を上書きしてください。
# =====================================================================

# ----- AI Gateway --------------------------------------------------
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ----- Stripe ------------------------------------------------------
# テスト用は "sk_test_..." / "pk_test_..." 形式、本番は "sk_live_..." / "pk_live_..." 形式
# Stripe Dashboard → 開発者 → API キー から取得して値を貼り付ける
STRIPE_SECRET_KEY=<YOUR_STRIPE_SECRET_KEY>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<YOUR_STRIPE_PUBLISHABLE_KEY>

# Stripe Dashboard の商品カタログから取得した Price ID
STRIPE_PRICE_MONTHLY=<YOUR_STRIPE_PRICE_ID_MONTHLY>
STRIPE_PRICE_ANNUAL=<YOUR_STRIPE_PRICE_ID_ANNUAL>

# Stripe Webhook シークレット (本番設定時に必要・開発中は空でも可)
STRIPE_WEBHOOK_SECRET=<YOUR_STRIPE_WEBHOOK_SECRET>
