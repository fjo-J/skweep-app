# =====================================================================
# Skweep — 環境変数サンプル
# このファイルをコピーして .env.local を作成し、値を上書きしてください。
# =====================================================================

# ----- AI Gateway --------------------------------------------------
# 使用する AI プロバイダ: openai / anthropic / gemini
# 未指定なら anthropic + claude-haiku-4-5 にフォールバック。
AI_PROVIDER=anthropic

# プロバイダ固有のモデル ID。
#   anthropic 例: claude-haiku-4-5 / claude-sonnet-4-6
#   openai    例: gpt-4.1-mini / gpt-4o-mini
#   gemini    例: gemini-2.0-flash / gemini-1.5-flash
AI_MODEL=claude-haiku-4-5

# 実 API キー (Phase 7 以降で使用)。Phase 6 時点では未使用。
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
